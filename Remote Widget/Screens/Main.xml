<body>
    <tabview key="selectedTab" value="Home">
        <navigationstack tabItem="label:Home;systemImage:house" tag="Home">
            <remoteview src="resource:Home"/>
        </navigationstack>
        
        <navigationstack tabItem="label:🐈‍⬛ Messenger;systemImage:bubble.left" tag="Messages">
            <remoteview src="resource:Chat"/>
        </navigationstack>

        <navigationstack tabItem="label:Settings;systemImage:gear" tag="Settings">
            <remoteview src="resource:Settings"/>
        </navigationstack>
    </tabview>

    
    <dialogs>
        <alert id="alertMessageSent" messageTitle="Sent">
        </alert>
        
        <alert id="alertMessageFailed" alertTitle="Sending Failed" alertMessage="$msgError">
        </alert>
    </dialogs>
    
</body>

